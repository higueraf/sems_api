		{
			"name": "Auth",
			"item": [
				{
					"name": "Login",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"if (pm.response.code === 200) {",
									"    const response = pm.response.json();",
									"    pm.collectionVariables.set('auth_token', response.access_token);",
									"    pm.collectionVariables.set('user_id', response.user.id);",
									"    pm.collectionVariables.set('user_email', response.user.email);",
									"    pm.collectionVariables.set('user_role', response.user.role);",
									"    ",
									"    // Guardar token para requests posteriores",
									"    pm.globals.set('bearer_token', 'Bearer ' + response.access_token);",
									"    ",
									"    console.log('Login exitoso - Token guardado');",
									"} else {",
									"    console.error('Error en login:', pm.response.json());",
									"}"
								]
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"email\": \"{{admin_email}}\",\n    \"password\": \"{{admin_password}}\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/auth/login",
							"host": ["{{base_url}}"],
							"path": ["auth", "login"]
						}
					}
				},
