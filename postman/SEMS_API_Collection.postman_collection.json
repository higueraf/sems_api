	"event": [
		{
			"listen": "prerequest",
			"script": {
				"type": "text/javascript",
				"exec": [
					"// Agregar headers comunes para todas las requests",
					"if (pm.request.url.includes('/auth/login') === false) {",
					"    pm.request.headers.add({",
					"        'Authorization': pm.collectionVariables.get('bearer_token') || 'Bearer ' + pm.collectionVariables.get('auth_token')",
					"        'Content-Type': 'application/json'",
					"    });",
					"}"
				]
