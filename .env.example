# ══════════════════════════════════════════════════════════════════════════════
# SEMS API — Variables de entorno (.env.example)
# Copie este archivo como .env para desarrollo local.
# En Render / Railway / Fly.io: configure en el panel de variables de entorno.
# ══════════════════════════════════════════════════════════════════════════════

# ── Servidor ──────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=production
APP_URL=https://sems-api.onrender.com
FRONTEND_URL=https://tu-sitio.netlify.app

# ── Base de datos (Neon) ──────────────────────────────────────────────────────
DB_HOST=ep-billowing-cloud-adtffkrx-pooler.c-2.us-east-1.aws.neon.tech
DB_PORT=5432
DB_USER=neondb_owner
DB_PASS=tu_password_neon
DB_NAME=sems_db
DB_SSL=true

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_SECRET=cambia_esto_por_algo_muy_secreto_en_produccion
JWT_EXPIRES_IN=7d


# ══════════════════════════════════════════════════════════════════════════════
# CORREO ELECTRÓNICO — Sistema multi-transporte
# ══════════════════════════════════════════════════════════════════════════════
#
# MAIL_FROM: dirección visible para el destinatario (en todos los transportes)
MAIL_FROM="II Simposio Ciencia Abierta <noreply@tu-dominio.com>"
#
# MAIL_TRANSPORT: fuerza un transporte específico.
#   Valores: smtp | resend | gmail
#   Si se omite, el sistema auto-detecta según las variables presentes
#   con esta prioridad: gmail → resend → smtp
#
# MAIL_TRANSPORT=gmail


# ── OPCIÓN A: Gmail API — Capa gratuita de Google Cloud ───────────────────────
#
# CUÁNDO USAR:
#   Cualquier entorno (Render, Railway, Fly.io, VPS, local).
#   No usa SMTP → no está bloqueada en Render free.
#   Cuota gratuita: ~10.000 correos/día sin tarjeta de crédito.
#
# SUB-OPCIÓN A1: OAuth2 con Refresh Token (recomendada — cuenta @gmail.com)
#
#   PASOS DE CONFIGURACIÓN:
#   1. Crear proyecto en https://console.cloud.google.com
#   2. APIs & Services → Library → buscar "Gmail API" → Enable
#   3. APIs & Services → Credentials → Create → OAuth 2.0 Client ID
#      · Application type: Desktop app
#      · Descargar JSON (contiene client_id y client_secret)
#   4. Obtener Refresh Token:
#      · Ir a https://developers.google.com/oauthplayground
#      · ⚙️ Settings → "Use your own OAuth credentials"
#      · Pegar Client ID y Client Secret
#      · En "Select & authorize APIs" escribir:
#        https://www.googleapis.com/auth/gmail.send
#      · Authorize APIs → iniciar sesión con la cuenta Gmail
#      · Exchange authorization code for tokens
#      · Copiar el "Refresh token"
#
# MAIL_TRANSPORT=gmail
# GMAIL_USER=prof.francisco.higuera@gmail.com
# GMAIL_CLIENT_ID=123456789-abcdefghijklmnop.apps.googleusercontent.com
# GMAIL_CLIENT_SECRET=GOCSPX-xxxxxxxxxxxxxxxxxxxxxxxx
# GMAIL_REFRESH_TOKEN=1//0exxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

#
# SUB-OPCIÓN A2: Service Account (solo Google Workspace — dominio propio)
#   Requiere Google Workspace Business y activar Domain-Wide Delegation.
#
# MAIL_TRANSPORT=gmail
# GMAIL_USER=correo@su-dominio.com
# GMAIL_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"mi-proyecto",...}


# ── OPCIÓN B: Resend — API REST (plan gratuito 3.000 correos/mes) ──────────────
#
# CUÁNDO USAR:
#   Render plan gratuito, Vercel, Lambda y entornos que bloquean SMTP.
#   Más simple de configurar que Gmail API si no tiene cuenta Google Cloud.
#
# PASOS:
#   1. Crear cuenta en https://resend.com
#   2. API Keys → Create API Key → copiar re_xxx
#   3. Domains → Add Domain → verificar registros DNS para usar dominio propio
#      (sin dominio verificado solo entrega al email del dueño de la cuenta)
#
# MAIL_TRANSPORT=resend
# RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx


# ── OPCIÓN C: SMTP clásico (nodemailer) ───────────────────────────────────────
#
# CUÁNDO USAR:
#   Desarrollo local, VPS propios, Railway, Fly.io, Hostinger.
#   NO usar en Render free (bloquea el puerto 587).
#
# PASOS PARA GMAIL:
#   1. myaccount.google.com → Seguridad → Verificación en 2 pasos (activar)
#   2. Al final de esa página: "Contraseñas de aplicaciones"
#   3. Crear una para "Correo" → "SEMS API"
#   4. Usar los 16 caracteres como MAIL_PASS
#   IMPORTANTE: MAIL_FROM debe usar la misma dirección que MAIL_USER
#
# MAIL_TRANSPORT=smtp
# MAIL_HOST=smtp.gmail.com
# MAIL_PORT=587
# MAIL_USER=prof.francisco.higuera@gmail.com
# MAIL_PASS=abcd efgh ijkl mnop


# ── CLOUDINARY — fotos e imágenes (25 GB gratis permanentes) ─────────────────
CLOUDINARY_CLOUD_NAME=tu_cloud_name
