# ════════════════════════════════════════════════════════════════════════════
# SEMS API — Variables de entorno
# ════════════════════════════════════════════════════════════════════════════
# Copiar a .env y completar los valores según el entorno de despliegue.
# Las credenciales cloud son OPCIONALES — si se omiten, el sistema usa disco local.

# ── Servidor ─────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=production

# URL pública del backend (sin slash final) — usada para construir URLs de descarga local
APP_URL=https://tu-dominio.com

# URL del frontend (para CORS)
# Puede ser una sola URL o múltiples URLs separadas por comas
# Ejemplos:
# FRONTEND_URL=https://tu-frontend.com
# FRONTEND_URL=http://localhost:5173,http://localhost:5174,https://staging.tu-dominio.com,https://tu-dominio.com
FRONTEND_URL=https://tu-frontend.com

# ── Base de datos (PostgreSQL) ────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_USER=sems_user
DB_PASS=super_secret_password
DB_NAME=sems_db
DB_SSL=false

# ── JWT ──────────────────────────────────────────────────────────────────────
JWT_SECRET=cambia_esto_por_una_clave_larga_y_aleatoria
JWT_EXPIRES_IN=7d

# ── Correo electrónico ────────────────────────────────────────────────────────
# Selector: 'gmail' | 'resend' | 'smtp'  (auto-detecta si se omite)
MAIL_TRANSPORT=gmail
MAIL_FROM="SEMS <noreply@tudominio.com>"

# OPCIÓN A: Gmail API OAuth2 (recomendado — 10.000 correos/día gratis)
GMAIL_USER=tucuenta@gmail.com
GMAIL_CLIENT_ID=xxxx.apps.googleusercontent.com
GMAIL_CLIENT_SECRET=GOCSPX-xxxx
GMAIL_REFRESH_TOKEN=1//xxxx

# OPCIÓN B: SMTP (Gmail App Password, Brevo, etc.)
# MAIL_HOST=smtp.gmail.com
# MAIL_PORT=587
# MAIL_USER=tucuenta@gmail.com
# MAIL_PASS=app_password_de_16_chars

# OPCIÓN C: Resend (serverless / Render free)
# RESEND_API_KEY=re_xxxx

# ════════════════════════════════════════════════════════════════════════════
# ALMACENAMIENTO — Modo 1: Cloud (recomendado para producción)
# ════════════════════════════════════════════════════════════════════════════
# Si se configuran ambos (Cloudinary + B2), el sistema usa cloud completo.
# Si se omiten, se usa disco local automáticamente (ver Modo 2 abajo).

# Cloudinary — fotos e imágenes (25 GB gratis)
# Registro: https://cloudinary.com/users/register/free
CLOUDINARY_CLOUD_NAME=tu_cloud_name
CLOUDINARY_API_KEY=123456789012345
CLOUDINARY_API_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Backblaze B2 — documentos Word y PDFs (10 GB gratis, API S3-compatible)
# Registro: https://www.backblaze.com/b2/sign-up.html
# Endpoint: Settings → Buckets → Endpoint (ej: s3.us-west-004.backblazeb2.com)
B2_KEY_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxx
B2_APP_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxx
B2_ENDPOINT=s3.us-west-004.backblazeb2.com
B2_BUCKET=sems-docs

# ════════════════════════════════════════════════════════════════════════════
# ALMACENAMIENTO — Modo 2: Disco local / VPS (sin credenciales cloud)
# ════════════════════════════════════════════════════════════════════════════
# Se activa automáticamente cuando Cloudinary y/o B2 no están configurados.
#
# UPLOAD_DEST puede ser ruta absoluta o relativa al directorio de ejecución:
#
#   VPS propio (recomendado, persistente):
#     UPLOAD_DEST=/var/www/sems/uploads
#
#   Docker con volumen montado:
#     UPLOAD_DEST=/data/uploads
#
#   Render / Railway (efímero — se pierde al redeploy):
#     UPLOAD_DEST=./uploads   ← solo para pruebas, NO para producción
#
# En modo local los archivos se sirven via:
#   Imágenes públicas:   GET /api/local-files/public/<folder>/<filename>
#   Docs privados:       GET /api/local-files/private/<folder>/<filename>  (requiere JWT)
#   Legacy /uploads/*:   GET /uploads/<folder>/<filename>  (static assets)
#
UPLOAD_DEST=./uploads

# Tamaño máximo por archivo (bytes). Default: 15 MB.
# MAX_FILE_SIZE=15728640
